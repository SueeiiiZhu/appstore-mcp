[Unit]
Description=Apple App Store Connect Reports MCP Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/apple-mcp
ExecStart=/usr/local/bin/uv run python -m apple_mcp --http --port 3000
EnvironmentFile=/opt/apple-mcp/.env
Restart=always
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=apple-mcp

[Install]
WantedBy=multi-user.target
