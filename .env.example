# App Store Connect API credentials
# Get these from https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
APP_STORE_CONNECT_VENDOR_NUMBER=12345678

# Optional local archive root for historical reports beyond Apple's 1-year API window
# Replace this placeholder with your own real path if you want local report loading.
APP_STORE_REPORT_LOCAL_DIR=/path/to/apple-reports
